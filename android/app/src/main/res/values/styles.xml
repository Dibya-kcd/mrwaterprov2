<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- App launch theme shown while Flutter initializes. -->
    <style name="LaunchTheme" parent="@android:style/Theme.DeviceDefault.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/black</item>
    </style>

    <!-- Normal app theme used after Flutter loads. -->
    <style name="NormalTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
    </style>
</resources>
